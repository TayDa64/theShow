{
  "name": "the-show",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && ! grep -R \"GEMINI_API_KEY\" dist/assets && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "test": "vitest run --coverage",
    "test:ffmpeg": "vitest run tests/ffmpeg-assembly.test.ts",
    "test:rate-limit": "vitest run tests/rate-limit.smoke.test.ts",
    "test:veo-chain": "vitest run tests/veo-chain.test.ts",
    "test:storage": "vitest run tests/storage-manager.test.ts",
    "test:routes": "vitest run tests/film-routes.test.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "uuid": "^11.1.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.5.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.9"
  }
}
